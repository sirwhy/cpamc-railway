# ===== CPAMC AI Framework v3 - Environment Variables =====
# Copy file ini jadi .env untuk development lokal.
# Di Railway: isi semuanya di Settings > Variables.

# === WAJIB ===
CPAMC_BASE_URL=https://cli-proxy-api-production-9440.up.railway.app/v1
CPAMC_API_KEY=dummy

# === MODEL (OPSIONAL — biarkan kosong untuk auto-detect dari 9router) ===
# Jika diisi, akan override auto-detect. Contoh: claude-sonnet-4-5 | gpt-4o
MODEL=
MAX_TOKENS=4096
TEMPERATURE=0.7
MAX_HISTORY=60

# === TELEGRAM BOT (wajib untuk bot Telegram) ===
# Dapatkan token dengan chat @BotFather di Telegram → /newbot
TELEGRAM_BOT_TOKEN=

# === MONGODB (sangat direkomendasikan — memori & history tidak hilang) ===
# Format: mongodb+srv://username:password@cluster.mongodb.net/cpamc
# Gratis dari MongoDB Atlas: https://cloud.mongodb.com
# Tersedia via GitHub Student Developer Pack (Atlas 50 USD kredit + M0 Free)
# Lihat docs/RAILWAY_MONGODB_SETUP.md untuk panduan lengkap.
MONGODB_URI=

# === SECURITY ===
# Telegram User ID yang diizinkan (pisah koma). Kosong = semua user bisa.
# Cara dapat user ID: chat @userinfobot di Telegram
ALLOWED_USERS=

# === VOICE TRANSCRIPTION (opsional) ===
# Untuk transkripsi voice message via Whisper API
# Dapatkan API key di: https://platform.openai.com
OPENAI_API_KEY=

# === DATA STORAGE (fallback bila MongoDB tidak tersedia) ===
DATA_DIR=./data

# === SERVER ===
PORT=3000
TZ=Asia/Jakarta

# ───────────────────────────────────────────────────────────
# === FITUR LANJUTAN (port dari claude-code-telegram) ====
# ───────────────────────────────────────────────────────────

# === SCHEDULER (cron job persisten) ===
# Set "true" untuk auto-start scheduler saat boot.
# Job dibuat via API: POST /api/jobs (lihat docs/FEATURES.md)
ENABLE_SCHEDULER=false

# === NOTIFICATIONS (broadcast ke Telegram) ===
# Chat ID Telegram default untuk menerima broadcast dari webhook & scheduler.
# Pisah koma, contoh: 123456789,-100200300400 (private + supergroup)
NOTIFICATION_CHAT_IDS=

# === WEBHOOK SERVER ===
# GitHub webhook (HMAC-SHA256). Set secret yang sama di GitHub repo settings.
GITHUB_WEBHOOK_SECRET=

# Generic webhook bearer token. Provider lain harus kirim:
#   Authorization: Bearer <WEBHOOK_API_SECRET>
WEBHOOK_API_SECRET=

# Set "true" agar webhook otomatis trigger AI follow-up via engine.
WEBHOOK_TRIGGER_AI=false

# Set "false" untuk menonaktifkan broadcast otomatis ke NOTIFICATION_CHAT_IDS.
WEBHOOK_BROADCAST=true
