# ===== CPAMC AI Framework v3 - Environment Variables =====
# Copy file ini jadi .env untuk development lokal
# Di Railway: isi semua ini di Settings > Variables

# === WAJIB ===
CPAMC_BASE_URL=https://cli-proxy-api-production-9440.up.railway.app/v1
CPAMC_API_KEY=dummy

# === MODEL (OPSIONAL — biarkan kosong untuk auto-detect dari 9router) ===
# Jika diisi, akan override auto-detect. Contoh: claude-sonnet-4-5 | gpt-4o
MODEL=
MAX_TOKENS=4096
TEMPERATURE=0.7

# === TELEGRAM BOT (wajib untuk bot Telegram) ===
# Cara dapat: chat @BotFather di Telegram > /newbot
TELEGRAM_BOT_TOKEN=

# === MONGODB (sangat direkomendasikan — memori & history tidak hilang) ===
# Format: mongodb+srv://username:password@cluster.mongodb.net/cpamc
# Gratis dari MongoDB Atlas: https://cloud.mongodb.com
# (Tersedia via GitHub Student Pack)
MONGODB_URI=


# Isi dengan Telegram User ID, pisah koma. Kosongkan = semua bisa akses
# Cara dapat user ID: chat @userinfobot di Telegram
ALLOWED_USERS=

# === VOICE TRANSCRIPTION (opsional) ===
# Untuk fitur transkripsi pesan suara via Whisper API
# Dapatkan API key di: https://platform.openai.com
OPENAI_API_KEY=

# === DATA STORAGE ===
# Railway: gunakan /tmp (volatile) atau mount persistent storage
DATA_DIR=./data

# === SERVER ===
PORT=3000
